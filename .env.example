# ─── Database ────────────────────────────────────────────
DATABASE_URL="postgresql://postgres:password@localhost:5432/ledx_elearn_dev"

# ─── Redis (Upstash) ─────────────────────────────────────
REDIS_URL="redis://localhost:6379"

# ─── JWT ─────────────────────────────────────────────────
JWT_ACCESS_SECRET="change-me-access-secret-min-32-chars"
JWT_REFRESH_SECRET="change-me-refresh-secret-min-32-chars"
JWT_ACCESS_EXPIRES_IN="15m"
JWT_REFRESH_EXPIRES_IN="7d"

# ─── Cloudflare R2 ───────────────────────────────────────
R2_ACCOUNT_ID="your-cloudflare-account-id"
R2_ACCESS_KEY_ID="your-r2-access-key"
R2_SECRET_ACCESS_KEY="your-r2-secret-key"
R2_BUCKET_NAME="ledx-elearn-dev"
R2_PUBLIC_URL="https://pub-xxx.r2.dev"

# ─── Mux ─────────────────────────────────────────────────
MUX_TOKEN_ID="your-mux-token-id"
MUX_TOKEN_SECRET="your-mux-token-secret"
MUX_WEBHOOK_SECRET="your-mux-webhook-secret"

# ─── Razorpay ────────────────────────────────────────────
RAZORPAY_KEY_ID="rzp_test_xxx"
RAZORPAY_KEY_SECRET="your-razorpay-secret"
RAZORPAY_WEBHOOK_SECRET="your-razorpay-webhook-secret"

# ─── Resend ──────────────────────────────────────────────
RESEND_API_KEY="re_xxx"
FROM_EMAIL="noreply@lexed.in"

# ─── Python AI Service ───────────────────────────────────
AI_SERVICE_URL="http://localhost:8000"
AI_SERVICE_SECRET="internal-secret-token"

# ─── Public (exposed to browser) ─────────────────────────
NEXT_PUBLIC_RAZORPAY_KEY_ID="rzp_test_xxx"
NEXT_PUBLIC_MUX_ENV_KEY="your-mux-env-key"
NEXT_PUBLIC_APP_URL="http://localhost:3000"
